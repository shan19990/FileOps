# Copy this file to ".env" and fill in your values.

# Required: your OpenAI API key
OPENAI_API_KEY=sk-your-key-here

# Model used to classify files (vision-capable model required for images).
# gpt-5 is strongest; gpt-4o-mini is cheaper with much higher rate limits.
OPENAI_CHAT_MODEL=gpt-5

# Model used to create embeddings for the RAG store
OPENAI_EMBED_MODEL=text-embedding-3-small

# Max characters of text read from a file before truncating
MAX_TEXT_CHARS=8000

# Max width/height (px) images are resized to before being sent to the model
MAX_IMAGE_DIM=1024

# Folder where the RAG vector store is persisted
RAG_DIR=.rag_store
